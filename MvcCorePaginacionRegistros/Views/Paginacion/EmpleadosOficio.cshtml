@model List<Empleado>

<h1>Paginacion con Filtros</h1>
<form method="post">
    <label>Introduzca oficio</label>
    <input type="text" name="oficio" class="form-control"/>
    <button class="btn btn-warning">Buscar Empleados</button>
</form>

<hr />
@{
    int numRegistros = 0;
    int numPagina = 1;
    string oficio = "";
    if (ViewData["OFICIO"] != null)
    {
        numRegistros = (int)ViewData["REGISTROS"];
        oficio = (string)ViewData["OFICIO"];
    }
}
<hr />
@if (Model != null)
{
    @for (int i = 1; i <= numRegistros; i += 3)
    {
        <a asp-controller="Paginacion" asp-action="EmpleadosOficio"
           asp-route-posicion="@i" asp-route-oficio="@oficio"
           class="btn btn-dark">Página @numPagina</a>
        numPagina++;
    }
    <table class="table table-striped table-dark">
        <thead>
            <tr>
                <th>Id</th>
                <th>Apellido</th>
                <th>Oficio</th>
                <th>Salario</th>
                <th>Departamento</th>
            </tr>
        </thead>
        <tbody>
            @foreach (Empleado emp in Model)
            {
                <tr>
                    <td>@emp.IdEmpleado</td>
                    <td>@emp.Apellido</td>
                    <td>@emp.Oficio</td>
                    <td>@emp.Salario</td>
                    <td>@emp.IdDepartamento</td>
                </tr>
            }
        </tbody>
    </table>
}