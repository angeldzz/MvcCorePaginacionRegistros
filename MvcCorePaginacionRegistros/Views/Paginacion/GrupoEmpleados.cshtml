@model List<Empleado>
@{
    int numRegistros = (int)ViewData["REGISTROS"];
    int numPagina = 1;
}
<h1>Paginacion en grupo</h1>
@for (int i = 1; i <= numRegistros; i += 3)
{
    <a asp-controller="Paginacion" asp-action="GrupoEmpleados" asp-route-posicion="@i"
       class="btn btn-success">Página @numPagina</a>
    numPagina++;
}
<hr />
<hr />
<table class="table table-striped table-success">
    <thead>
        <tr>
            <th>Id</th>
            <th>Apellido</th>
            <th>Oficio</th>
            <th>Salario</th>
            <th>Departamento</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Empleado emp in Model)
        {
            <tr>
                <td>@emp.IdEmpleado</td>
                <td>@emp.Apellido</td>
                <td>@emp.Oficio</td>
                <td>@emp.Salario</td>
                <td>@emp.IdDepartamento</td>
            </tr>
        }
    </tbody>
</table>